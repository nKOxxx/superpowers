{
  "name": "browse",
  "version": "1.0.0",
  "description": "Browser automation for visual testing and QA with Playwright. Use when user needs to test web applications, capture screenshots, validate UI flows, or perform automated browser actions.",
  "author": "nKO",
  "entry": {
    "type": "node",
    "bin": "node",
    "args": ["dist/browse/index.js"]
  },
  "triggers": [
    "/browse",
    "screenshot",
    "visual testing",
    "browser automation",
    "UI testing"
  ],
  "requires": {
    "bins": ["node", "npx"],
    "npm": ["@nko/superpowers", "playwright"]
  },
  "env": {},
  "config": {
    "schema": {
      "viewports": {
        "type": "object",
        "description": "Custom viewport definitions"
      },
      "defaultViewport": {
        "type": "string",
        "enum": ["mobile", "tablet", "desktop"],
        "default": "desktop"
      },
      "screenshotDir": {
        "type": "string",
        "default": "./screenshots"
      }
    }
  },
  "examples": [
    {
      "prompt": "/browse https://example.com",
      "description": "Capture screenshot of URL"
    },
    {
      "prompt": "/browse https://example.com --viewport=mobile",
      "description": "Mobile viewport screenshot"
    },
    {
      "prompt": "/browse https://example.com --full-page",
      "description": "Full page screenshot"
    }
  ]
}
