{
  "name": "plan-ceo-review",
  "version": "1.0.0",
  "description": "Product strategy review using BAT framework (Brand, Attention, Trust)",
  "author": "nKO",
  "entry": {
    "type": "node",
    "bin": "node",
    "args": ["cli.js"]
  },
  "triggers": [
    "/plan-ceo-review",
    "should we build",
    "feature evaluation",
    "product strategy",
    "build vs buy"
  ],
  "requires": {
    "bins": ["node"],
    "npm": []
  },
  "env": {},
  "config": {
    "schema": {
      "minimumScore": {
        "type": "number",
        "default": 10,
        "description": "Minimum BAT score (0-15) to recommend building"
      },
      "autoGenerateNextSteps": {
        "type": "boolean",
        "default": true
      }
    }
  },
  "examples": [
    {
      "prompt": "/plan-ceo-review \"Mobile App: Customer-facing iOS/Android app\"",
      "description": "Evaluate mobile app idea"
    },
    {
      "prompt": "/plan-ceo-review \"AI Feature\" --brand=4 --attention=5 --trust=3",
      "description": "Review with manual BAT scores"
    }
  ]
}
