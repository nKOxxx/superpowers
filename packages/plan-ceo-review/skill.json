{
  "name": "plan-ceo-review",
  "version": "1.0.0",
  "description": "BAT framework for product decisions",
  "entry": "dist/index.js",
  "command": "plan-ceo-review",
  "args": ["question"],
  "options": {
    "auto": {
      "type": "boolean",
      "description": "Auto-generate BAT analysis without interactive prompts",
      "default": false
