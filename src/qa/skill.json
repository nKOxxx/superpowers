{
  "name": "qa",
  "description": "Systematic testing as QA Lead - targeted, smoke, or full regression",
  "version": "1.0.0",
  "entry": "dist/qa/index.js",
  "commands": {
    "qa": {
      "description": "Run tests based on code changes",
      "options": {
        "mode": {
          "type": "string",
          "description": "Test mode: targeted, smoke, full",
          "default": "targeted"
        },
        "coverage": {
          "type": "boolean",
          "description": "Enable coverage reporting"
        },
        "watch": {
          "type": "boolean",
          "description": "Watch mode for development"
        }
      }
    }
  }
}
