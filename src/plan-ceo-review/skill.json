{
  "name": "plan-ceo-review",
  "description": "BAT framework product strategy review - Brand, Attention, Trust scoring",
  "version": "1.0.0",
  "entry": "dist/plan-ceo-review/index.js",
  "commands": {
    "ceo-review": {
      "description": "Evaluate feature using BAT framework",
      "args": ["feature"],
      "options": {
        "goal": {
          "type": "string",
          "description": "Business goal this feature serves"
        },
        "brand": {
          "type": "number",
          "description": "Brand alignment score (0-5)"
        },
        "attention": {
          "type": "number",
          "description": "Attention capture score (0-5)"
        },
        "trust": {
          "type": "number",
          "description": "Trust building score (0-5)"
        }
      }
    }
  }
}
