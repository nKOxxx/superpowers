{
  "name": "ship",
  "version": "1.0.0",
  "description": "One-command release pipeline with semantic versioning and GitHub releases",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "package": "mkdir -p ../../dist-skills && tar -czf ../../dist-skills/ship.skill.tar.gz skill.json package.json dist/",
    "clean": "rm -rf dist",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/semver": "^7.5.6",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
