{
  "name": "plan-ceo-review",
  "version": "1.0.0",
  "description": "BAT framework for product strategy decisions with 10-star methodology",
  "entry": "dist/index.js",
  "type": "node",
  "bin": {
    "ceo-review": "dist/cli.js"
  },
  "config": {
    "thresholds": {
      "build": { "minStars": 10, "minCategories": 2 },
      "consider": { "minStars": 7, "minCategories": 2 },
      "skip": { "minStars": 0 }
    }
  }
}
