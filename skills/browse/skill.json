{
  "name": "browse",
  "version": "1.0.0",
  "description": "Browser automation with Playwright for screenshots and flow testing",
  "entry": "dist/index.js",
  "type": "node",
  "bin": {
    "browse": "dist/cli.js"
  },
  "config": {
    "viewports": {
      "mobile": { "width": 375, "height": 667 },
      "tablet": { "width": 768, "height": 1024 },
      "desktop": { "width": 1920, "height": 1080 }
    }
  }
}
