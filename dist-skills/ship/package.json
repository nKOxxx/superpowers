{
  "name": "@superpowers/ship",
  "version": "1.0.0",
  "description": "One-command release pipeline - version bump, changelog, GitHub release",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ship": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "semver": "^7.6.0",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/semver": "^7.5.8",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "release",
    "version",
    "changelog",
    "semantic-versioning",
    "github",
    "npm",
    "superpowers"
  ],
  "license": "MIT"
}
