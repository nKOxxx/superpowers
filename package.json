{
  "name": "@nko/superpowers",
  "version": "1.0.0",
  "description": "TypeScript skill collection for OpenClaw - browser automation, QA testing, release management, and product strategy",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "superpowers": "./dist/cli.js",
    "browse": "./packages/browse/cli.js",
    "qa": "./packages/qa/cli.js",
    "ship": "./packages/ship/cli.js",
    "plan-ceo-review": "./packages/plan-ceo-review/cli.js"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "build:common": "npm run build --workspace=packages/common",
    "build:browse": "npm run build --workspace=packages/browse",
    "build:qa": "npm run build --workspace=packages/qa",
    "build:ship": "npm run build --workspace=packages/ship",
    "build:plan-ceo-review": "npm run build --workspace=packages/plan-ceo-review",
    "clean": "npm run clean --workspaces",
    "lint": "eslint packages/*/src/**/*.ts",
    "test": "npm run test --workspaces",
    "package:all": "./package-skills.sh"
  },
  "keywords": [
    "openclaw",
    "superpowers",
    "browser-automation",
    "testing",
    "release",
    "product-strategy",
    "playwright",
    "cli",
    "typescript"
  ],
  "author": "nKO",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "playwright": "^1.42.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "semver": "^7.6.0",
    "simple-git": "^3.22.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/semver": "^7.5.8",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0",
    "eslint": "^8.57.0"
  }
}
