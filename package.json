{
  "name": "@nko/superpowers",
  "version": "1.0.0",
  "description": "OpenClaw superpowers - AI-powered workflows for development, testing, and product decisions",
  "type": "module",
  "main": "cli.js",
  "bin": {
    "superpowers": "cli.js"
  },
  "scripts": {
    "build": "tsc && npm run build:skills",
    "build:skills": "for dir in skills/*/; do (cd \"$dir\" && tsc); done",
    "package": "npm run package:skills && ./package.sh",
    "package:skills": "for dir in skills/*/; do (cd \"$dir\" && npm pack); done",
    "test": "npm run test:skills",
    "test:skills": "echo 'Tests TBD'",
    "clean": "rm -rf dist skills/*/dist",
    "dev": "tsc --watch"
  },
  "keywords": [
    "openclaw",
    "superpowers",
    "browser-automation",
    "testing",
    "release",
    "product-strategy"
  ],
  "author": "nKO",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ora": "^3.1.0",
    "@types/semver": "^7.7.1",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "ora": "^8.0.0",
    "playwright": "^1.40.0",
    "semver": "^7.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
