{
  "name": "@nko/superpowers",
  "version": "1.0.0",
  "description": "OpenClaw Superpowers - Browser automation, QA, shipping, and product strategy",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "superpowers": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "package": "npm run build && npm run package:skills",
    "package:skills": "node scripts/package-skills.js",
    "test": "vitest",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "openclaw",
    "superpowers",
    "browser",
    "automation",
    "qa",
    "testing",
    "release",
    "product-strategy"
  ],
  "author": "nKO",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "playwright": "^1.42.0",
    "ora": "^8.0.1",
    "simple-git": "^3.22.0",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/semver": "^7.5.8",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  }
}