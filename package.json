{
  "name": "@nko/superpowers",
  "version": "1.0.0",
  "description": "OpenClaw superpowers - AI-powered workflows for development, testing, and product decisions",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "npm run clean --workspaces && rm -rf dist-skills",
    "package": "npm run build && npm run package:skills",
    "package:skills": "node scripts/package-skills.js",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "skills",
    "cli",
    "automation",
    "testing",
    "release"
  ],
  "author": "nKO",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/semver": "^7.7.1",
    "playwright": "^1.58.2",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
