{
  "name": "@nko/superpowers",
  "version": "1.0.0",
  "description": "OpenClaw superpowers - AI-driven development workflows",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "superpowers": "./cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:skills": "npm run build && npm run package:skills",
    "package:skills": "node scripts/package-skills.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["openclaw", "skills", "ai", "automation", "testing", "browser"],
  "author": "Nikola Kolev <nko@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nKOxxx/superpowers.git"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "playwright": "^1.40.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
