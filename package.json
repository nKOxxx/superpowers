{
  "name": "@nko/superpowers",
  "version": "1.0.0",
  "description": "OpenClaw Superpowers - AI-powered workflows for development, testing, and product decisions",
  "main": "dist/index.js",
  "bin": {
    "superpowers": "./cli.js"
  },
  "scripts": {
    "build": "tsc",
    "package": "npm run build && npm run package:skills",
    "package:skills": "bash package-skills.sh",
    "clean": "rm -rf dist dist-skills",
    "test": "vitest"
  },
  "keywords": [
    "openclaw",
    "skills",
    "browser",
    "testing",
    "release",
    "product-strategy"
  ],
  "author": "Ares",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "playwright": "^1.40.0",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/semver": "^7.5.6",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
