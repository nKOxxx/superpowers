{
  "name": "superpowers",
  "version": "1.0.0",
  "description": "AI-powered workflows for development, testing, and product decisions",
  "type": "module",
  "main": "cli.js",
  "bin": {
    "superpowers": "./cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist dist-skills",
    "package": "npm run package:browse && npm run package:qa && npm run package:ship && npm run package:ceo-review",
    "package:browse": "./scripts/package-skill.sh browse",
    "package:qa": "./scripts/package-skill.sh qa",
    "package:ship": "./scripts/package-skill.sh ship",
    "package:ceo-review": "./scripts/package-skill.sh ceo-review",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["openclaw", "superpowers", "cli", "automation", "testing", "release"],
  "author": "nKOxxx",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "ora": "^8.0.1",
    "playwright": "^1.40.0",
    "semver": "^7.5.4"
  }
}
