{
  "name": "@nko/superpowers",
  "version": "1.0.0",
  "description": "AI-powered workflows for development, testing, and product decisions",
  "type": "module",
  "main": "cli.js",
  "bin": {
    "superpowers": "./cli.js"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "build:all": "npm run build --workspaces",
    "package": "npm run package --workspaces",
    "package:all": "npm run package --workspaces",
    "test": "npm run test --workspaces",
    "clean": "rm -rf dist dist-skills && npm run clean --workspaces",
    "dev": "tsx watch skills/browse/src/index.ts"
  },
  "workspaces": [
    "skills/*"
  ],
  "keywords": [
    "openclaw",
    "skills",
    "browser-automation",
    "testing",
    "release",
    "product-strategy"
  ],
  "author": "nKO",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nKOxxx/superpowers.git"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  }
}
