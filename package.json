{
  "name": "@nko/superpowers",
  "version": "1.0.0",
  "description": "TypeScript skill collection for OpenClaw - browser automation, QA testing, release management, and product strategy",
  "type": "module",
  "workspaces": [
    "browse",
    "qa",
    "ship",
    "plan-ceo-review"
  ],
  "bin": {
    "superpowers": "./cli.js",
    "browse": "./browse/dist/cli.js",
    "qa": "./qa/dist/cli.js",
    "ship": "./ship/dist/cli.js",
    "plan-ceo-review": "./plan-ceo-review/dist/cli.js"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "build:browse": "npm run build --workspace=browse",
    "build:qa": "npm run build --workspace=qa",
    "build:ship": "npm run build --workspace=ship",
    "build:plan-ceo-review": "npm run build --workspace=plan-ceo-review",
    "clean": "rm -rf */dist */node_modules node_modules",
    "lint": "echo 'Linting not configured'",
    "test": "npm run test --workspaces",
    "package:all": "./package-skills.sh"
  },
  "keywords": [
    "openclaw",
    "superpowers",
    "browser-automation",
    "testing",
    "release",
    "product-strategy",
    "playwright",
    "cli",
    "typescript"
  ],
  "author": "nKO",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  }
}
