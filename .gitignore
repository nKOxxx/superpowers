# Ignore files for packaging

# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Testing
coverage/
*.log

# Environment
.env
.env.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Package outputs
dist-skills/*/
dist-skills/*.skill
*.tgz
# But keep the packaged .skill.tar.gz files
!dist-skills/*.skill.tar.gz
